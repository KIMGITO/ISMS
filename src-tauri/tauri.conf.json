{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "KayKay's",
  "version": "0.1.0",
  "identifier": "com.kaykays.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "KayKay's",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "downloadUrl": "https://github.com/tauri-apps/binary-releases/releases/download/nsis-3.09/nsis-3.09.zip"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
