# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# VITE_AI_NAME: Custom workspace assistant AI name (e.g., Kim)
VITE_AI_NAME="Kim"

# Supabase Connection Config (For both client and edge functions)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
DATABASE_URL="postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres"
VITE_UNSPLASH_ACCESS_KEY="your-unsplash-access-key"

# Vite client exposed variables (Required for production build exports)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Real Email Delivery SMTP Configuration
# Set these to send emails directly to real inboxes instead of using the Ethereal sandbox fallback.
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your-email@example.com"
SMTP_PASS="your-email-password"
